# Database
# For local development, use a local SQLite file:
DATABASE_URL="file:./dev.db"
# For production (Turso):
TURSO_DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin Seed (change in production!)
ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_PASSWORD="change-me-in-production"

# AWS S3 (optional - uses Vercel Blob if not set)
AWS_REGION="us-west-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""

# Vercel Blob (auto-set when Blob store is connected)
BLOB_READ_WRITE_TOKEN=""
